{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@ardnt/vercel-python-slim",
      "config": {
        "runtime": "python3.9" 
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}